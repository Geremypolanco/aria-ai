# Copy to .env in this same directory and fill in the generated secrets —
# never commit the real .env. This is a minimal, verified subset of
# Activepieces' own configuration; check their current .env.example for the
# full/latest list before a production deploy:
# https://github.com/activepieces/activepieces/blob/main/.env.example

# 256-bit encryption key, 32 hex characters: openssl rand -hex 16
AP_ENCRYPTION_KEY=

# JWT signing secret: openssl rand -hex 32
AP_JWT_SECRET=

AP_ENVIRONMENT=prod
# Public URL this instance is reachable at (used in webhook/callback links).
AP_FRONTEND_URL=http://localhost:8080

AP_POSTGRES_DATABASE=activepieces
AP_POSTGRES_HOST=postgres
AP_POSTGRES_PORT=5432
AP_POSTGRES_USERNAME=postgres
AP_POSTGRES_PASSWORD=

AP_REDIS_HOST=redis
AP_REDIS_PORT=6379

AP_EXECUTION_MODE=UNSANDBOXED
AP_WEBHOOK_TIMEOUT_SECONDS=30
AP_TRIGGER_DEFAULT_POLL_INTERVAL=5
AP_TELEMETRY_ENABLED=true
