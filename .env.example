# ARIA AI — Environment Configuration
# Copy this to .env and fill in your keys

# Environment
ENVIRONMENT=development
PORT=8000

# Owner
OWNER_NAME=Tu Nombre
OWNER_EMAIL=tu@email.com

# Telegram (optional)
TELEGRAM_TOKEN=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Database (optional)
SUPABASE_URL=
SUPABASE_KEY=
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
REDIS_URL=

# HuggingFace (primary AI engine)
HF_TOKEN=
HF_API_KEY=

# Groq (fallback AI)
GROQ_API_KEY=

# OpenAI (secondary fallback)
OPENAI_API_KEY=

# Stripe (payments)
STRIPE_API_KEY=

# Shopify (ecommerce)
SHOPIFY_API_KEY=
SHOPIFY_PASSWORD=
SHOPIFY_STORE_NAME=

# Sentry (error tracking)
SENTRY_DSN=

# Security
ARIA_API_KEY=