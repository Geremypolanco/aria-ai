# ============================================================
  # ARIA AI — Variables de entorno para Fly.io
  # Agregar con: fly secrets set KEY=VALUE
  # ============================================================

  # ── OBLIGATORIAS (ya configuradas) ─────────────────────────
  TELEGRAM_BOT_TOKEN=
  TELEGRAM_CHAT_ID=
  SUPABASE_URL=
  SUPABASE_KEY=
  REDIS_URL=
  GROQ_API_KEY=
  OPENAI_API_KEY=

  # ── IA ADICIONAL ────────────────────────────────────────────
  # ANTHROPIC_API_KEY=           # claude.ai → API Keys
  # GEMINI_API_KEY=              # aistudio.google.com
  # ELEVENLABS_API_KEY=          # elevenlabs.io → Profile → API Key
  # DEEPGRAM_API_KEY=            # console.deepgram.com

  # ── MONETIZACIÓN DIRECTA ────────────────────────────────────
  STRIPE_SECRET_KEY=             # dashboard.stripe.com → Developers → API Keys
  # GUMROAD_TOKEN=               # app.gumroad.com → Settings → Advanced → Access Token
  # LEMONSQUEEZY_API_KEY=        # app.lemonsqueezy.com → Settings → API
  # LEMONSQUEEZY_STORE_ID=       # ID de tu tienda en LemonSqueezy
  # PAYPAL_CLIENT_ID=            # developer.paypal.com → Apps & Credentials
  # PAYPAL_CLIENT_SECRET=        # developer.paypal.com → Apps & Credentials
  # COINBASE_COMMERCE_API_KEY=   # commerce.coinbase.com → Settings → Security

  # ── AFILIADOS (Fase 1 — PRIORIDAD MÁXIMA) ──────────────────
  # AMAZON_ASSOCIATE_TAG=        # affiliate-program.amazon.com → tu tag (ej: aria-ai-20)
  # CLICKBANK_AFFILIATE_ID=      # accounts.clickbank.com → tu nickname
  # HOTMART_BASIC_TOKEN=         # developers.hotmart.com → Credentials → Basic Token

  # ── PUBLICACIÓN DE CONTENIDO ───────────────────────────────
  # MEDIUM_TOKEN=                # medium.com/me/settings → Integration Token
  # DEVTO_API_KEY=               # dev.to/settings/extensions → API Keys
  # HASHNODE_TOKEN=              # hashnode.com → Account Settings → Developer → PAT
  # HASHNODE_PUBLICATION_ID=     # ID de tu blog en Hashnode

  # ── REDES SOCIALES ADICIONALES ─────────────────────────────
  # (Facebook/Instagram/TikTok/LinkedIn — ver /conectar en Telegram)
  ARIA_BASE_URL=https://aria-ai.fly.dev
  # FACEBOOK_APP_ID=             # developers.facebook.com → Tu app
  # FACEBOOK_APP_SECRET=         # developers.facebook.com → Tu app
  # TIKTOK_CLIENT_KEY=           # developers.tiktok.com
  # TIKTOK_CLIENT_SECRET=        # developers.tiktok.com
  # LINKEDIN_CLIENT_ID=          # linkedin.com/developers → Tu app
  # LINKEDIN_CLIENT_SECRET=      # linkedin.com/developers → Tu app

  # Twitter/X
  # TWITTER_API_KEY=             # developer.twitter.com → Projects → Tu app
  # TWITTER_API_SECRET=          # developer.twitter.com
  # TWITTER_ACCESS_TOKEN=        # developer.twitter.com → Keys and Tokens
  # TWITTER_ACCESS_TOKEN_SECRET= # developer.twitter.com → Keys and Tokens

  # Reddit
  # REDDIT_CLIENT_ID=            # reddit.com/prefs/apps → create app
  # REDDIT_CLIENT_SECRET=        # reddit.com/prefs/apps
  # REDDIT_USERNAME=             # tu username de Reddit
  # REDDIT_PASSWORD=             # tu password de Reddit
  # REDDIT_TARGET_SUBREDDIT=     # ej: artificial (sin r/)

  # Pinterest
  # PINTEREST_ACCESS_TOKEN=      # developers.pinterest.com → OAuth token

  # Discord
  # DISCORD_WEBHOOK_URL=         # Tu servidor → Channel Settings → Integrations → Webhooks

  # ── EMAIL MARKETING ─────────────────────────────────────────
  # RESEND_API_KEY=              # resend.com → API Keys (3k emails/mes gratis)
  # SENDGRID_API_KEY=            # app.sendgrid.com → Settings → API Keys (100/día gratis)
  # MAILGUN_API_KEY=             # mailgun.com → API Keys (5k/mes trial)
  # MAILGUN_DOMAIN=              # tu dominio verificado en Mailgun
  # CONVERTKIT_API_KEY=          # app.convertkit.com → Settings → Developer
  # EMAIL_FROM=                  # ej: ARIA <aria@tudominio.com>
  # OWNER_EMAIL=                 # tu email para recibir alertas

  # ── SEO E INTELIGENCIA ──────────────────────────────────────
  # NEWS_API_KEY=                # newsapi.org (ya en config)
  # SERP_API_KEY=                # serpapi.com (ya en config)
  # PRODUCT_HUNT_TOKEN=          # api.producthunt.com → Apps

  # ── ANALÍTICAS ──────────────────────────────────────────────
  # SENTRY_DSN=                  # sentry.io → Proyectos → DSN

  # ── Cloudinary (imágenes/video) ─────────────────────────────
  # CLOUDINARY_CLOUD_NAME=       # cloudinary.com → Dashboard
  # CLOUDINARY_API_KEY=          # cloudinary.com → Dashboard
  # CLOUDINARY_API_SECRET=       # cloudinary.com → Dashboard
  