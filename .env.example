# ARIA AI — Environment Configuration
# Copy this file to `.env` and fill in real values. NEVER commit `.env`.
# All secrets are read from the environment via apps/core/config.py (pydantic
# BaseSettings) — nothing is hardcoded in the source.

# ── Runtime ───────────────────────────────────────────────
ENVIRONMENT=development
PORT=8000
ARIA_BASE_URL=https://aria-ai.fly.dev

# ── Owner / access control ────────────────────────────────
OWNER_NAME=Your Name
OWNER_EMAIL=you@example.com
# Owner-only password gating the /admin control panel.
ADMIN_PASSWORD=
# Dedicated HMAC key for signing user session cookies + OAuth state.
# REQUIRED in production — without it, sessions use an ephemeral per-process
# key (they won't survive restarts or span instances). Generate a strong one:
#   python -c "import secrets; print(secrets.token_hex(32))"
SESSION_SECRET=
# Optional public API key.
ARIA_API_KEY=
# Secret for signing outbound integration webhooks.
WEBHOOK_SECRET=

# ── OAuth (user login) ────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ── AI providers ──────────────────────────────────────────
# HuggingFace (primary engine)
HF_TOKEN=
HF_API_KEY=
# Groq (fast fallback)
GROQ_API_KEY=
# Anthropic (Claude — MCP client, Computer-Use agent, provider fallback)
ANTHROPIC_API_KEY=
# OpenAI (optional fallback)
OPENAI_API_KEY=
# Google / Cohere (optional)
GOOGLE_API_KEY=
COHERE_API_KEY=

# ── Web research providers (optional) ─────────────────────
NEWS_API_KEY=
SERP_API_KEY=
TAVILY_API_KEY=
BRAVE_API_KEY=
PEXELS_API_KEY=

# ── Media (optional) ──────────────────────────────────────
ELEVENLABS_API_KEY=
CLOUDINARY_URL=

# ── Datastores (optional) ─────────────────────────────────
SUPABASE_URL=
SUPABASE_KEY=
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
REDIS_URL=

# ── Payments (optional) ───────────────────────────────────
STRIPE_SECRET_KEY=
PAYPAL_CLIENT_ID=
PAYPAL_SECRET=
GUMROAD_TOKEN=

# ── Commerce / integrations (optional) ────────────────────
SHOPIFY_URL=
SHOPIFY_API_KEY=
SHOPIFY_ADMIN_TOKEN=
SHOPIFY_AUTOMATION_TOKEN=
BUFFER_TOKEN=
AIRTABLE_TOKEN=
MAILCHIMP_API_KEY=

# ── Social (optional) ─────────────────────────────────────
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_TOKEN_SECRET=
TWITTER_BEARER_TOKEN=
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_PASSWORD=
PINTEREST_ACCESS_TOKEN=
DISCORD_WEBHOOK_URL=
MEDIUM_TOKEN=
DEVTO_API_KEY=
HASHNODE_TOKEN=

# ── Notifications (optional) ──────────────────────────────
TELEGRAM_TOKEN=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
