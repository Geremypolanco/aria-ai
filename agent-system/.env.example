# ── Base de Datos ──
POSTGRES_USER=aria
POSTGRES_PASSWORD=aria_secret_change_me
POSTGRES_DB=aria_agents
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://aria:aria_secret_change_me@postgres:5432/aria_agents

# ── Redis ──
REDIS_HOST=redis
REDIS_PORT=6379

# ── Vault ──
VAULT_ADDR=http://vault:8200
VAULT_DEV_ROOT_TOKEN_ID=dev-root-token
VAULT_APPROLE_ROLE_ID=
VAULT_APPROLE_SECRET_ID=

# ── API ──
API_HOST=0.0.0.0
API_PORT=8000
API_SECRET_KEY=change-me-api-secret-2024

# ── Sandbox ──
SANDBOX_IMAGE=agent-sandbox:latest
SANDBOX_MEMORY_LIMIT=512m
SANDBOX_CPU_LIMIT=1.0
SANDBOX_TIMEOUT_SECONDS=120

# ── Browser ──
BROWSER_IMAGE=agent-browser:latest
BROWSER_TIMEOUT_SECONDS=60
BROWSER_HEADLESS=true

# ── Logging ──
LOG_LEVEL=INFO
LOG_FORMAT=json
